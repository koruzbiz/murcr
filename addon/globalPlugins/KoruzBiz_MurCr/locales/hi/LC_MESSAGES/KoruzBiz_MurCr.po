msgid "Koruz.biz MurCr"
msgstr "Koruz.biz MurCr"

msgid "MurCr Project Directory"
msgstr "MurCr प्रोजेक्ट डायरेक्टरी"

msgid "Select the project directory folder"
msgstr "प्रोजेक्ट डायरेक्टरी फ़ोल्डर चुनें"

msgid "An error occurred while identifying the application."
msgstr "एप्लिकेशन की पहचान करते समय त्रुटि हुई।"

msgid "An error occurred."
msgstr "एक त्रुटि हुई।"

msgid "Invalid procedure or file path."
msgstr "अमान्य प्रक्रिया या फ़ाइल पथ।"

msgid "MurCr"
msgstr "MurCr"

msgid "MurCr not found"
msgstr "MurCr नहीं मिला"

msgid "Opening with MurCr."
msgstr "MurCr के साथ खोला जा रहा है।"

msgid "Project folder opened."
msgstr "प्रोजेक्ट फ़ोल्डर खुल गया।"

msgid "Project folder path could not be found."
msgstr "प्रोजेक्ट फ़ोल्डर का पथ नहीं मिला।"

msgid "The MurCr add-on is not configured for this application."
